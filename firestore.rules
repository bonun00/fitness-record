rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // 
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - createdAt: timestamp
    //
    // Collection: workouts
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - rawText: string (required)
    //   - date: timestamp (required)
    //   - exercises: list (optional)
    //   - analysis: string (optional)
    //
    // ===============================================================

    // Collection: friendships
    // Document ID: requesterUid_receiverUid (sorted)
    // Fields:
    //   - userUids: list (required) - [uid1, uid2]
    //   - status: string (required) - 'accepted'
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isFriend(userId) {
      let id1 = request.auth.uid + '_' + userId;
      let id2 = userId + '_' + request.auth.uid;
      return exists(/databases/$(database)/documents/friendships/$(id1)) || 
             exists(/databases/$(database)/documents/friendships/$(id2));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() < 256;
    }

    function isValidWorkout(data) {
      return data.keys().hasAll(['userId', 'rawText', 'date']) &&
             data.userId == request.auth.uid &&
             data.rawText is string &&
             data.rawText.size() < 5000;
    }

    function isValidFriendship(data) {
      return data.keys().hasAll(['userUids', 'status']) &&
             data.userUids is list &&
             data.userUids.size() == 2 &&
             request.auth.uid in data.userUids &&
             data.status == 'accepted';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /_connection_test_/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow searching for friends
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /workouts/{workoutId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isFriend(resource.data.userId));
      allow create: if isAuthenticated() && isValidWorkout(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidWorkout(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.userUids;
      allow create: if isAuthenticated() && isValidFriendship(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.userUids;
    }

    match /cheers/{cheerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
